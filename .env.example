SENDER_EMAIL=your_qq_email@qq.com
SENDER_PASSWORD=your_qq_smtp_authorization_code
RECIPIENT_EMAIL=your_receive_email@qq.com
PORTFOLIO_FILE=portfolio.local.json

AI_ENABLED=true
AI_PROVIDER=qwen
DASHSCOPE_API_KEY=your_dashscope_api_key

# Optional:
# KIMI_API_KEY=your_kimi_api_key
# DEEPSEEK_API_KEY=your_deepseek_api_key
# SMTP_SERVER=smtp.qq.com
# SMTP_PORT=465
# If QQ mail closes the 587 connection in local scheduled runs, use 465.

# Optional A-share market data rotation.
# Eastmoney is the main broad-market source; Sina is used to fill skipped pages.
# Tencent/Sina/Yahoo are also used as single-symbol quote fallbacks.
# BROAD_MARKET_SOURCES=eastmoney,sina
# SINA_MARKET_NODE=hs_a
# SINA_MARKET_PAGE_SIZE=200
# BROAD_MARKET_PAGE_TIMEOUT_SECONDS=2
# SINA_MARKET_PAGE_TIMEOUT_SECONDS=3

# Optional local Galaxy Xingyao/AmazingData option basics.
# Do not commit your real password. Put it only in local .env or enter it through run_monitor_xingyao_once.ps1.
# XINGYAO_ENABLED=false
# XINGYAO_USER=your_xingyao_username
# XINGYAO_PASSWORD=your_xingyao_password
# XINGYAO_HOST=your_xingyao_host
# XINGYAO_PORT=your_xingyao_port
# XINGYAO_SDK_PATHS=C:\path\to\amazingdata_sdk;C:\path\to\xingyao_sdk

# Optional iFind HTTP API.
# Copy the Refresh Token from iFind Super Command > Account Details.
# Keep it only in local .env; do not commit or paste it into chat.
# IFIND_REFRESH_TOKEN=your_ifind_refresh_token
# IFIND_API_BASE_URL=https://quantapi.51ifind.com/api/v1
# IFIND_TIMEOUT=30

# Optional WindPy validation layer.
# Keep this off unless Wind terminal and Python API are installed locally.
# WIND_ENABLED=false
# WIND_WAIT_TIME=30
